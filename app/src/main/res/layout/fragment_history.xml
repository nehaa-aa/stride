<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_light"
    android:padding="20dp">

    <!-- Hero heading -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="places you've been"
        android:fontFamily="serif"
        android:textStyle="italic"
        android:textSize="28sp"
        android:textColor="@color/deep_harbor"
        android:letterSpacing="0.02"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="your trail, recorded"
        android:fontFamily="serif"
        android:textStyle="italic"
        android:textSize="13sp"
        android:textColor="@color/sea_salt_sage"
        android:layout_marginBottom="20dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_clear_history"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:text="Clear all history"
        android:textColor="@color/misty_pine"
        android:textAllCaps="false"
        android:textSize="13sp"
        android:fontFamily="serif"
        android:textStyle="italic"
        app:strokeColor="@color/misty_pine"
        app:strokeWidth="1dp"
        app:cornerRadius="14dp"
        android:backgroundTint="@color/bg_light"
        android:layout_marginBottom="16dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"/>

    <ListView
        android:id="@+id/lv_history"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@null"
        android:dividerHeight="0dp"/>

</LinearLayout>