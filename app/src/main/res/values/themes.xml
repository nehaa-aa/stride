<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.App_Tracker" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/arsenic</item>
        <item name="colorPrimaryDark">@color/bistre</item>
        <item name="colorAccent">@color/morning_blue</item>
        <item name="android:statusBarColor">@color/bistre</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowBackground">@color/bg_light</item>
    </style>

    <!-- Stride wordmark: elegant serif -->
    <style name="StrideTitle">
        <item name="android:fontFamily">serif</item>
        <item name="android:textStyle">italic</item>
        <item name="android:textSize">26sp</item>
        <item name="android:textColor">@color/american_silver</item>
        <item name="android:letterSpacing">0.04</item>
    </style>

    <style name="TabTextStyle" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">13sp</item>
        <item name="android:fontFamily">serif</item>
        <item name="textAllCaps">false</item>
        <item name="android:textStyle">italic</item>
    </style>
</resources>