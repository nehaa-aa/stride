<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Hero label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="your trail."
            android:fontFamily="serif"
            android:textStyle="italic"
            android:textSize="32sp"
            android:textColor="@color/deep_harbor"
            android:letterSpacing="0.02"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="places you've been"
            android:fontFamily="serif"
            android:textStyle="italic"
            android:textSize="13sp"
            android:textColor="@color/sea_salt_sage"
            android:layout_marginBottom="24dp"/>

        <!-- Coordinates Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/divider"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:background="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Current coordinates"
                        android:fontFamily="serif"
                        android:textStyle="italic"
                        android:textColor="@color/misty_pine"
                        android:textSize="12sp"
                        android:letterSpacing="0.08"/>

                    <!-- Quick Refresh icon button -->
                    <ImageButton
                        android:id="@+id/btn_get_location"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="@drawable/bg_circle_arsenic"
                        android:src="@drawable/ic_refresh"
                        android:contentDescription="Quick refresh"
                        android:padding="9dp"/>
                </LinearLayout>

                <!-- Latitude row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="14dp">

                    <TextView
                        android:layout_width="36dp"
                        android:layout_height="wrap_content"
                        android:text="LAT"
                        android:textColor="@color/sea_salt_sage"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.12"/>

                    <TextView
                        android:id="@+id/tv_latitude"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="--"
                        android:textSize="24sp"
                        android:fontFamily="serif"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginStart="10dp"/>

                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="@color/divider"/>

                <!-- Longitude row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingTop="14dp"
                    android:paddingBottom="16dp">

                    <TextView
                        android:layout_width="36dp"
                        android:layout_height="wrap_content"
                        android:text="LON"
                        android:textColor="@color/sea_salt_sage"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.12"/>

                    <TextView
                        android:id="@+id/tv_longitude"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="--"
                        android:textSize="24sp"
                        android:fontFamily="serif"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginStart="10dp"/>

                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="@color/divider"/>

                <!-- Address row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="14dp">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@android:drawable/ic_menu_mylocation"
                        app:tint="@color/sea_salt_sage"
                        android:layout_marginEnd="12dp"
                        android:layout_marginTop="3dp"/>

                    <TextView
                        android:id="@+id/tv_address"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Waiting for location fix…"
                        android:textSize="14sp"
                        android:fontFamily="serif"
                        android:textStyle="italic"
                        android:textColor="@color/text_liver"
                        android:lineHeight="22sp"/>

                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Start / Stop tracking -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_start_tracking"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="Start tracking"
                app:cornerRadius="16dp"
                android:backgroundTint="@color/deep_harbor"
                android:layout_marginEnd="8dp"
                android:textAllCaps="false"
                android:textSize="15sp"
                android:textColor="@color/driftwood_sand"
                android:fontFamily="serif"
                android:textStyle="italic"
                android:insetTop="0dp"
                android:insetBottom="0dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_stop_tracking"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="Stop"
                app:cornerRadius="16dp"
                android:backgroundTint="@color/driftwood_sand"
                android:layout_marginStart="8dp"
                android:textAllCaps="false"
                android:textSize="15sp"
                android:textColor="@color/deep_harbor"
                android:fontFamily="serif"
                android:textStyle="italic"
                android:insetTop="0dp"
                android:insetBottom="0dp"/>

        </LinearLayout>

        <!-- Insights section label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Explore"
            android:fontFamily="serif"
            android:textStyle="italic"
            android:textColor="@color/deep_harbor"
            android:textSize="18sp"
            android:layout_marginBottom="12dp"
            android:layout_marginStart="2dp"/>

        <!-- Live Map card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btn_open_map"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/divider"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="18dp"
                android:background="@color/white">

                <LinearLayout
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:gravity="center"
                    android:background="@drawable/bg_rounded_map"
                    android:layout_marginEnd="14dp">
                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@android:drawable/ic_menu_mapmode"
                        app:tint="@color/deep_harbor"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Live map"
                        android:fontFamily="serif"
                        android:textStyle="bold|italic"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="See your trail in real time"
                        android:fontFamily="serif"
                        android:textStyle="italic"
                        android:textColor="@color/sea_salt_sage"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@android:drawable/ic_media_next"
                    app:tint="@color/sea_salt_sage"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Share button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_share_location"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Share my current coordinates"
            android:textColor="@color/deep_harbor"
            android:textAllCaps="false"
            android:textSize="14sp"
            android:fontFamily="serif"
            android:textStyle="italic"
            app:strokeColor="@color/misty_pine"
            app:strokeWidth="1.5dp"
            app:cornerRadius="16dp"
            app:icon="@android:drawable/ic_menu_share"
            app:iconTint="@color/deep_harbor"
            android:layout_marginTop="8dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="shake to quick refresh"
            android:layout_gravity="center"
            android:gravity="center"
            android:fontFamily="serif"
            android:textStyle="italic"
            android:layout_marginTop="20dp"
            android:textColor="@color/sea_salt_sage"
            android:textSize="12sp"
            android:alpha="0.7"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>